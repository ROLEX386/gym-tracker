{
  "name": "gym_tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gymtracker.desktop",
    "productName": "Gym Tracker",
    "directories": {
      "output": "C:/Users/karna/OneDrive/Desktop/GymTracker_Build"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "date-fns": "^3.6.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.4.1",
    "wait-on": "^9.0.4"
  }
}
